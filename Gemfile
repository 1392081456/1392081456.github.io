source "https://rubygems.org"

# GitHub Pages — uses the github-pages gem to track GH Pages' supported versions
gem "github-pages", group: :jekyll_plugins

# Plugins (allow-listed by GitHub Pages)
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

# Windows / WSL compatibility
gem "wdm", "~> 0.1.1", :install_if => Gem.win_platform?
